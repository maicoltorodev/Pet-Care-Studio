# ==========================================
# PET CARE STUDIO FRONTEND (.env.local.example)
# ==========================================

# 1. Base de Datos (Supabase)
# Copiado del panel principal de tu proyecto en Supabase (Settings -> API)
NEXT_PUBLIC_SUPABASE_URL="https://tu-id-proyecto.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="tu_anon_key_publica_aqui"

# 2. Conexión con el Backend Node.js
# URL donde vive el orquestador de IA (ej: localhost para dev o Railway para prod)
NEXT_PUBLIC_API_URL="http://localhost:3000"

# 3. Seguridad Admin Frontend -> Backend
# La misma clave secreta que configuraste en el Backend para invalidar su caché
ADMIN_API_KEY="super_secret_admin_key_123_cambiar_en_produccion"

# 4. SEO y Metadatos
# La URL base de tu sitio en producción
SITE_URL="https://petcarestudio.vercel.app"
